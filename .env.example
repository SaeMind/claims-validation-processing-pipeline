# --- GCP project / region ---
GCP_PROJECT_ID=my-healthcare-project
GCP_REGION=us-central1

# --- Pub/Sub topics ---
RAW_CLAIMS_TOPIC=incoming-claims
VALID_CLAIMS_TOPIC=valid-claims
INVALID_CLAIMS_TOPIC=invalid-claims
RETRY_CLAIMS_TOPIC=retry-claims
MANUAL_REVIEW_TOPIC=manual-review-claims
REJECTED_CLAIMS_TOPIC=rejected-claims
ALERTS_TOPIC=claims-alerts

# --- BigQuery ---
BIGQUERY_DATASET=claims_analytics
BIGQUERY_VALIDATED_TABLE=validated_claims
BIGQUERY_AGGREGATE_TABLE=member_claim_aggregates
MEMBER_RISK_TABLE=member_risk_scores
ICD10_REFERENCE_TABLE=icd10_codes
CPT_REFERENCE_TABLE=cpt_codes

# --- Provider reference store (Cloud SQL / local Postgres) ---
CLOUDSQL_INSTANCE=your-project:us-central1:claims-reference-db
CLOUDSQL_DATABASE=claims_ref
CLOUDSQL_USER=postgres
CLOUDSQL_PASSWORD=replace-me
CLOUDSQL_DRIVER=postgresql+pg8000

# --- Validation thresholds ---
MAX_CLAIM_AMOUNT=100000
MAX_PROCEDURE_AMOUNT=50000
MAX_CLAIM_AGE_DAYS=3650
MAX_FUTURE_SERVICE_DAYS=7

# --- Enrichment / fraud thresholds ---
HIGH_COST_THRESHOLD=10000
DUPLICATE_CACHE_TTL_SECONDS=86400

# --- Runtime ---
OUTPUT_DIR=outputs
LOG_LEVEL=INFO
ENABLE_BIGQUERY=false
ENABLE_PUBSUB_PUBLISH=false
LOCAL_MODE=false

# --- Local emulator (docker-compose only) ---
PUBSUB_EMULATOR_HOST=localhost:8085
